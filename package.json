{
  "name": "@rehx/api-client-generator",
  "version": "0.1.0",
  "description": "Generate a typesafe fetch-based API client from an OpenAPI 3.x spec",
  "type": "module",
  "bin": {
    "api-client-generator": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ajiohjesse/api-client-generator.git"
  },
  "keywords": [
    "openapi",
    "api-client",
    "codegen",
    "typescript",
    "fetch"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "prepublishOnly": "npm run build && npm run test",
    "semantic-release": "semantic-release"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "js-yaml": "^4.1.0",
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.4.0",
    "@commitlint/config-conventional": "^19.4.0",
    "@semantic-release/github": "^11.0.0",
    "@semantic-release/npm": "^12.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.5.0",
    "@vitest/coverage-v8": "^2.1.0",
    "husky": "^9.1.0",
    "semantic-release": "^24.1.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.0"
  },
  "license": "MIT"
}
